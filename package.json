{
  "name": "demo_workspace",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:dev": "cross-env ENV=dev npx playwright test ",
    "test:qa": "cross-env ENV=qa npx playwright test tests/loginenvbased.spec.ts",
    "test:uat": "cross-env ENV=uat npx playwright test",
    "test:prod": "cross-env ENV=prod npx playwright test",
    "clean": "rimraf allure-results allure-report",
    "pretest": "npm run clean",
    "test": "npx playwright test tests/button.spec.ts || cd .",
    "posttest": "npm run report-generate && npm run report-open",
    "report-generate": "allure generate allure-results --clean -o allure-report",
    "report-open": "allure open allure-report",
    "test2": "npm run clean && npx playwright test tests/button.spec.ts || cd . && npm run report-generate && npm run report-open"
    
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-playwright": "^3.8.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "dotenv": "^17.4.2"
  }
}
